PORT=3001
CLIENT_URL=http://localhost:5173

# Base de datos Postgres (Fase 2 — cuentas). Consigue esta URL cuando crees
# la base de datos en Render (o donde la hospedes) y pégala aquí.
DATABASE_URL=postgresql://usuario:contrasena@host:5432/nombre_basedatos

# Cualquier texto largo y secreto que se te ocurra, para firmar las sesiones.
JWT_SECRET=cambia-esto-por-un-texto-largo-y-secreto
